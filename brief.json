    "document_html": "<!DOCTYPE html>\n<html lang=\"fr\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Simulateur de Potentiel Solaire | Paramètres de votre Installation</title>\n    <meta name=\"description\" content=\"Estimez la production d\">\n    <style>\n        :root {\n            --color-primary: #3a5068;\n            --color-secondary: #ae6977;\n            --color-accent: #68ae69;\n            --color-text: #333;\n            --color-background: #f7f7f7;\n            --color-card-bg: #ffffff;\n            --gradient-soft: linear-gradient(135deg, rgba(255,255,255,0.1), rgba(0,0,0,0.05));\n            --shadow-subtle: 0 4px 10px rgba(0,0,0,0.05);\n            --border-radius: 8px;\n            --font-family-headline: 'Montserrat', sans-serif;\n            --font-family-body: 'Roboto', sans-serif;\n        }\n\n        @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@600;700&family=Roboto:wght@300;400&display=swap');\n\n        body {\n            font-family: var(--font-family-body);\n            color: var(--color-text);\n            margin: 0;\n            padding: 0;\n            background-color: var(--color-background);\n            line-height: 1.6;\n        }\n\n        header {\n            background-color: var(--color-primary);\n            color: #fff;\n            padding: 1.5rem 0;\n            text-align: center;\n            box-shadow: var(--shadow-subtle);\n        }\n\n        header h1 {\n            font-family: var(--font-family-headline);\n            font-weight: 700;\n            margin: 0;\n            font-size: 2.2rem;\n        }\n\n        .container {\n            max-width: 1200px;\n            margin: 2rem auto;\n            padding: 0 1.5rem;\n            display: grid;\n            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));\n            gap: 2rem;\n        }\n\n        .card {\n            background-color: var(--color-card-bg);\n            padding: 2rem;\n            border-radius: var(--border-radius);\n            box-shadow: var(--shadow-subtle);\n            border: 1px solid rgba(0,0,0,0.05);\n            transition: transform 0.2s ease-in-out;\n            background: var(--color-card-bg) var(--gradient-soft);\n        }\n\n        .card:hover {\n            transform: translateY(-5px);\n        }\n\n        h2 {\n            font-family: var(--font-family-headline);\n            color: var(--color-primary);\n            font-weight: 600;\n            margin-top: 0;\n            font-size: 1.6rem;\n            border-bottom: 2px solid var(--color-secondary);\n            padding-bottom: 0.5rem;\n            margin-bottom: 1.5rem;\n        }\n\n        label {\n            display: block;\n            margin-bottom: 0.5rem;\n            color: var(--color-text);\n            font-weight: 400;\n        }\n\n        input[type=\"number\"],\n        select {\n            width: calc(100% - 20px);\n            padding: 10px;\n            margin-bottom: 1rem;\n            border: 1px solid #ccc;\n            border-radius: var(--border-radius);\n            box-sizing: border-box;\n            font-family: var(--font-family-body);\n            font-size: 1rem;\n            background-color: #fcfcfc;\n        }\n        input[type=\"number\"]:focus,\n        select:focus {\n            outline: none;\n            border-color: var(--color-accent);\n            box-shadow: 0 0 0 3px rgba(104, 174, 105, 0.2);\n        }\n\n\n        button {\n            background-color: var(--color-secondary);\n            color: white;\n            padding: 12px 25px;\n            border: none;\n            border-radius: var(--border-radius);\n            cursor: pointer;\n            font-size: 1.1rem;\n            font-family: var(--font-family-headline);\n            font-weight: 600;\n            transition: background-color 0.2s ease, transform 0.2s ease;\n            display: block;\n            width: fit-content;\n            margin-top: 1.5rem;\n        }\n\n        button:hover {\n            background-color: #a05a68;\n            transform: translateY(-2px);\n        }\n\n        .result-section {\n            background-color: var(--color-card-bg);\n            padding: 2rem;\n            border-radius: var(--border-radius);\n            box-shadow: var(--shadow-subtle);\n            grid-column: 1 / -1; /* Spans across all columns */\n            margin-top: 2rem;\n            background: var(--color-card-bg) var(--gradient-soft);\n        }\n\n        .result-item {\n            display: flex;\n            justify-content: space-between;\n            padding: 0.8rem 0;\n            border-bottom: 1px dashed rgba(0,0,0,0.1);\n        }\n\n        .result-item:last-child {\n            border-bottom: none;\n        }\n\n        .result-item strong {\n            color: var(--color-primary);\n            font-family: var(--font-family-headline);\n        }\n\n        .result-item span {\n            font-weight: 400;\n        }\n\n        .seo-section {\n            background-color: var(--color-primary);\n            color: #fff;\n            padding: 2rem 1.5rem;\n            margin-top: 3rem;\n            text-align: center;\n            border-top: 5px solid var(--color-accent);\n            font-size: 0.9rem;\n        }\n\n        .seo-section h3 {\n            font-family: var(--font-family-headline);\n            font-weight: 600;\n            font-size: 1.4rem;\n            margin-bottom: 1rem;\n        }\n\n        .seo-section p {\n            max-width: 900px;\n            margin: 0.5rem auto;\n            line-height: 1.8;\n            opacity: 0.9;\n        }\n\n        .seo-section a {\n            color: var(--color-accent);\n            text-decoration: none;\n            transition: color 0.2s ease;\n        }\n\n        .seo-section a:hover {\n            color: #fff;\n        }\n\n        @media (max-width: 768px) {\n            .container {\n                grid-template-columns: 1fr;\n            }\n            header h1 {\n                font-size: 1.8rem;\n            }\n            h2 {\n                font-size: 1.4rem;\n            }\n            button {\n                width: 100%;\n            }\n        }\n    </style>\n    <meta name=\"robots\" content=\"index, follow\">\n    <link rel=\"canonical\" href=\"https://simulateur-de-potentiel-solaire-1.onrender.com\">\n    <meta property=\"og:title\" content=\"Simulateur de Potentiel Solaire\">\n    <meta property=\"og:description\" content=\"Estimez la production d\">\n    <meta property=\"og:url\" content=\"https://simulateur-de-potentiel-solaire-1.onrender.com\">\n    <meta property=\"og:type\" content=\"website\">\n    <script type=\"application/ld+json\">{\"@context\": \"https://schema.org\", \"@type\": \"WebApplication\", \"name\": \"Simulateur de Potentiel Solaire\", \"description\": \"Estimez la production d\", \"url\": \"https://simulateur-de-potentiel-solaire-1.onrender.com\", \"applicationCategory\": \"UtilityApplication\", \"operatingSystem\": \"Web Browser\"}</script>\n</head>\n<body data-site-slug=\"simulateur-de-potentiel-solaire-1\" data-runtime-mode=\"generic_calculator\">\n    <header>\n        <h1>Simulateur de Potentiel Énergétique Solaire</h1>\n        <p>Estimez la production et la rentabilité de votre projet photovoltaïque</p>\n    </header>\n\n    <div class=\"container\">\n        <form id=\"tool-form\" class=\"card\">\n            <h2>Paramètres de votre Installation</h2>\n\n            <label for=\"localisation\">Code Postal (France Métropolitaine)</label>\n            <input type=\"number\" id=\"localisation\" value=\"75001\" min=\"1000\" max=\"98999\" required>\n\n            <label for=\"orientation\">Orientation de votre Toiture</label>\n            <select id=\"orientation\" required>\n                <option value=\"sud\">Sud (idéal)</option>\n                <option value=\"sud-est\">Sud-Est</option>\n                <option value=\"sud-ouest\">Sud-Ouest</option>\n                <option value=\"est\">Est</option>\n                <option value=\"ouest\">Ouest</option>\n                <option value=\"nord\">Nord (peu recommandé)</option>\n            </select>\n\n            <label for=\"inclinaison\">Inclinaison des Panneaux (en degrés)</label>\n            <input type=\"number\" id=\"inclinaison\" value=\"35\" min=\"0\" max=\"90\" required>\n\n            <label for=\"surface\">Surface disponible (m²)</label>\n            <input type=\"number\" id=\"surface\" value=\"30\" min=\"5\" required>\n\n            <label for=\"puissance-creste\">Puissance crête par m² (Wc/m²)</label>\n            <input type=\"number\" id=\"puissance-creste\" value=\"180\" min=\"100\" max=\"250\" required>\n\n            <label for=\"consommation-annuelle\">Consommation annuelle (kWh)</label>\n            <input type=\"number\" id=\"consommation-annuelle\" value=\"4000\" min=\"500\" required>\n\n            <label for=\"prix-kwh\">Prix moyen du kWh (€)</label>\n            <input type=\"number\" id=\"prix-kwh\" value=\"0.25\" step=\"0.01\" min=\"0.10\" max=\"0.50\" required>\n\n            <label for=\"cout-installation\">Coût estimé de l'installation (€)</label>\n            <input type=\"number\" id=\"cout-installation\" value=\"9000\" min=\"1000\" required>\n\n            <button type=\"submit\" id=\"tool-submit\">Calculer mon Potentiel Solaire</button>\n        </form>\n\n        <div class=\"card\">\n            <h2>Comprendre les Paramètres</h2>\n            <p><strong>Code Postal :</strong> Influence l'ensoleillement et les subventions régionales.</p>\n            <p><strong>Orientation :</strong> Un toit orienté plein Sud offre le meilleur rendement. Les orientations Est et Ouest permettent de mieux capter l'énergie matin et soir.</p>\n            <p><strong>Inclinaison :</strong> En France, une inclinaison entre 30 et 35 degrés est souvent optimale pour maximiser la production annuelle.</p>\n            <p><strong>Surface :</strong> La place disponible détermine le nombre de panneaux que vous pouvez installer et donc la puissance totale.</p>\n            <p><strong>Puissance crête/m² :</strong> Indique l'efficacité de vos panneaux. Un chiffre plus élevé signifie plus de puissance sur une même surface.</p>\n            <p><strong>Consommation annuelle :</strong> Pour évaluer l'autoconsommation et la part de vos besoins couverts.</p>\n            <p><strong>Prix du kWh :</strong> Permet d'estimer les économies réalisées sur votre facture.</p>\n            <p><strong>Coût installation :</strong> Le prix total de votre projet, essentiel pour calculer le retour sur investissement.</p>\n        </div>\n\n        <div id=\"tool-result\" class=\"result-section\" style=\"display: none;\">\n            <h2 id=\"result-headline\">Vos Résultats Estimés</h2>\n            <div class=\"result-item\">\n                <strong>Production annuelle estimée :</strong> <span id=\"production-annuelle\"></span> kWh\n            </div>\n            <div class=\"result-item\">\n                <strong>Puissance crête totale :</strong> <span id=\"puissance-totale\"></span> Wc\n            </div>\n            <div class=\"result-item\">\n                <strong>Économies annuelles estimées :</strong> <span id=\"economies-annuelles\"></span> €\n            </div>\n            <div class=\"result-item\">\n                <strong>Taux d'autoconsommation :</strong> <span id=\"autoconsommation\"></span> %\n            </div>\n            <div class=\"result-item\">\n                <strong>Retour sur Investissement (amortissement) :</strong> <span id=\"retour-investissement\"></span> ans\n            </div>\n            <p style=\"margin-top: 1.5rem; font-size: 0.9rem; color: #666;\">Ces estimations sont indicatives et basées sur des moyennes nationales. Pour une étude précise, consultez un professionnel local.</p>\n            <button data-affiliate-slot=\"installation-devis\" style=\"background-color: var(--color-accent); margin-top: 1.5rem;\">Demander un devis personnalisé</button>\n        </div>\n    </div>\n\n    <div class=\"seo-section\">\n        <h3>Votre Projet Solaire en France : De l'Idée à la Réalisation</h3>\n        <p>Découvrez le potentiel de l'énergie solaire pour votre habitation en France. Que vous soyez en <strong>Île-de-France</strong>, en <strong>Occitanie</strong>, en <strong>PACA</strong>, ou partout ailleurs, notre simulateur vous offre une première estimation de la <a href=\"#\">rentabilité de vos panneaux solaires</a>. Comprenez comment optimiser votre <a href=\"#\">autoconsommation solaire</a>, évaluez les <a href=\"#\">économies d'énergie</a> réalisables et le <a href=\"#\">retour sur investissement photovoltaïque</a>. Nos outils vous aident à démystifier l'installation de <a href=\"#\">panneaux photovoltaïques</a> sur votre toit. Estimez la <a href=\"#\">production électrique annuelle</a> et les aides disponibles pour le <a href=\"#\">financement solaire</a> en France. Comparez les différentes <a href=\"#\">technologies de panneaux solaires</a> et trouvez le meilleur <a href=\"#\">installateur RGE</a> près de chez vous pour une transition énergétique réussie.</p>\n    </div>\n\n    <script>\n        document.getElementById('tool-form').addEventListener('submit', function(event) {\n            event.preventDefault();\n\n            const localisation = parseInt(document.getElementById('localisation').value);\n            const orientation = document.getElementById('orientation').value;\n            const inclinaison = parseInt(document.getElementById('inclinaison').value);\n            const surface = parseInt(document.getElementById('surface').value);\n            const puissanceCresteM2 = parseInt(document.getElementById('puissance-creste').value);\n            const consommationAnnuelle = parseInt(document.getElementById('consommation-annuelle').value);\n            const prixKwh = parseFloat(document.getElementById('prix-kwh').value);\n            const coutInstallation = parseFloat(document.getElementById('cout-installation').value);\n\n            // Mock data for regional insolation (kWh/kWp/year)\n            // Simplified for demonstration, a real app would use more granular data\n            const insolationData = {\n                'nord': { base: 900, nord: 0.7, est: 0.85, ouest: 0.85, sud_est: 0.95, sud_ouest: 0.95, sud: 1.0 }, // e.g., Lille\n                'centre': { base: 1100, nord: 0.6, est: 0.8, ouest: 0.8, sud_est: 0.9, sud_ouest: 0.9, sud: 0.98 }, // e.g., Paris\n                'sud': { base: 1300, nord: 0.5, est: 0.7, ouest: 0.7, sud_est: 0.85, sud_ouest: 0.85, sud: 0.95 } // e.g., Marseille\n            };\n\n            let regionKey;\n            if (localisation >= 1000 && localisation < 30000) { // North of France (rough estimate)\n                regionKey = 'nord';\n            } else if (localisation >= 30000 && localisation < 60000) { // Center of France\n                regionKey = 'centre';\n            } else { // South of France\n                regionKey = 'sud';\n            }\n\n            const regionInsolation = insolationData[regionKey].base;\n            const orientationFactor = insolationData[regionKey][orientation.replace('-', '_')]; // Normalize key\n\n            // Adjust for inclination (simplified, optimal is around 30-35 deg)\n            let inclinationFactor = 1.0;\n            if (inclinaison < 25 || inclinaison > 45) {\n                inclinationFactor = 0.9;\n            } else if (inclinaison < 15 || inclinaison > 60) {\n                inclinationFactor = 0.8;\n            }\n\n            const puissanceTotaleWc = surface * puissanceCresteM2;\n            const productionAnnuelleKWh = (puissanceTotaleWc / 1000) * regionInsolation * orientationFactor * inclinationFactor;\n\n            // Simplified Autoconsumption (e.g., 60-80% for domestic, depends on consumption pattern)\n            const autoconsommationRate = Math.min(1, consommationAnnuelle / productionAnnuelleKWh) * 0.7; // Assume 70% of production is autoconsumed within consumption limits\n            const productionAutoconsommee = Math.min(productionAnnuelleKWh * autoconsommationRate, consommationAnnuelle);\n            const economieAnnuelle = productionAutoconsommee * prixKwh;\n            \n            const retourSurInvestissement = coutInstallation / economieAnnuelle;\n\n            document.getElementById('production-annuelle').textContent = productionAnnuelleKWh.toFixed(0);\n            document.getElementById('puissance-totale').textContent = puissanceTotaleWc.toFixed(0);\n            document.getElementById('economies-annuelles').textContent = economieAnnuelle.toFixed(2);\n            document.getElementById('autoconsommation').textContent = (autoconsommationRate * 100).toFixed(0);\n            document.getElementById('retour-investissement').textContent = retourSurInvestissement.toFixed(1);\n\n            document.getElementById('tool-result').style.display = 'block';\n            document.getElementById('tool-result').scrollIntoView({ behavior: 'smooth' });\n        });\n    </script>\n<div id=\"qa-smoke-result\" hidden></div>\n<script id=\"farmbuilder-affiliate-helper\">\n(function () {\n  window.__UTILITY_AFFILIATE_MAP = window.__UTILITY_AFFILIATE_MAP || {};\n  document.addEventListener(\"click\", function (event) {\n    const target = event.target.closest(\"[data-affiliate-slot]\");\n    if (!target) return;\n    const slot = target.getAttribute(\"data-affiliate-slot\");\n    const href = window.__UTILITY_AFFILIATE_MAP[slot];\n    if (!href) return;\n    if (target.tagName && target.tagName.toLowerCase() === \"a\") {\n      target.setAttribute(\"href\", href);\n      target.setAttribute(\"rel\", \"nofollow sponsored noopener noreferrer\");\n      return;\n    }\n    event.preventDefault();\n    window.open(href, \"_blank\", \"noopener\");\n  }, true);\n})()